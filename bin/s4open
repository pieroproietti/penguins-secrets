#!/bin/bash
# s4open - Sblocca e monta il volume cifrato

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
source "$SCRIPT_DIR/s4config"

if [ ! -f "$CRYPTFILE" ]; then
    echo "[ERRORE] Il file $CRYPTFILE non esiste. Esegui prima s4create."
    exit 1
fi

echo "-> Apertura del contenitore cifrato..."
sudo cryptsetup luksOpen "$CRYPTFILE" "$CRYPTMAPPED"

echo "-> Montaggio del volume..."
mkdir -p "$CRYPTMNT"
#sudo mount -o uid=$(id -u),gid=$(id -g) /dev/mapper/"$CRYPTMAPPED" "$CRYPTMNT"
sudo mount /dev/mapper/"$CRYPTMAPPED" "$CRYPTMNT"

echo "-> Volume aperto e pronto all'uso in $CRYPTMNT!"
